# Copy this file to .env and fill in real values.

# --- Django ---
# Generate a real key for production, e.g.:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
# 1 for local development, 0 in production (Media3).
DEBUG=1
DJANGO_LOGLEVEL=info
# Comma-separated hostnames. In production set your Cornell hostname.
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# --- Production hardening (applied only when DEBUG=0) ---
# Comma-separated scheme+host origins for CSRF (login/POST) behind the HTTPS proxy.
# CSRF_TRUSTED_ORIGINS=https://laborhub.cornell.edu
# Redirect HTTP->HTTPS at the app layer (Apache also redirects). Default on in prod.
# SECURE_SSL_REDIRECT=1
# HTTP Strict Transport Security: start at 0, raise to 3600 then 31536000 once
# HTTPS is verified end-to-end.
# SECURE_HSTS_SECONDS=0

# --- Database ---
# Default: SQLite - zero setup, no DB server needed. Ideal for local development.
DATABASE_ENGINE=sqlite3

# For MySQL, set DATABASE_ENGINE=mysql above and use the values below.
#   * Local (non-Docker) MySQL: keep DATABASE_HOST=127.0.0.1 and start a MySQL server.
#   * Cornell Media3 (production): set DATABASE_HOST to the managed-MySQL hostname.
#   * `docker compose up`: Docker forces engine=mysql and host=db automatically, so
#     these credentials are used as-is regardless of DATABASE_ENGINE above.
DATABASE_NAME=nole
DATABASE_USERNAME=nole
DATABASE_PASSWORD=change-me
DATABASE_ROOT_PASSWORD=change-me-root
DATABASE_HOST=127.0.0.1
DATABASE_PORT=3306

# --- Optional: S3 storage for static/media (off by default) ---
USE_S3=False
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=us-east-2

# --- Optional: SMTP email (defaults to console backend) ---
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=noreply@laborhub.com

# --- Optional: gunicorn (production app server) ---
# Worker process count; default is (2 x CPU) + 1.
# WEB_CONCURRENCY=3
