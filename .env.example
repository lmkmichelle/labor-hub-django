# Copy this file to .env and fill in real values.

# --- Django ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DEBUG=1
DJANGO_LOGLEVEL=info
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# --- Database (MySQL, matches Cornell Media3) ---
DATABASE_ENGINE=mysql
DATABASE_NAME=nole
DATABASE_USERNAME=nole
DATABASE_PASSWORD=change-me
DATABASE_ROOT_PASSWORD=change-me-root
# Use "db" (the docker-compose service name) with Docker, or "127.0.0.1" without Docker.
DATABASE_HOST=db
DATABASE_PORT=3306

# Zero-setup local alternative: no MySQL needed, uses a local SQLite file.
# Set DATABASE_ENGINE=sqlite3 and the DATABASE_* values above are ignored.
# DATABASE_ENGINE=sqlite3

# --- Optional: S3 storage for static/media (off by default) ---
USE_S3=False
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_STORAGE_BUCKET_NAME=
# AWS_S3_REGION_NAME=us-east-2

# --- Optional: SMTP email (defaults to console backend) ---
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=
# EMAIL_HOST_PASSWORD=
# DEFAULT_FROM_EMAIL=noreply@laborhub.com
